# ===========================
# AUTOVERSE - Environment Variables
# ===========================

# --- DATABASE ---
DATABASE_URL="postgresql://user:password@localhost:5432/autoverse_db"

# --- JWT ---
JWT_SECRET="your_super_secret_jwt_key_change_in_production"
JWT_EXPIRES_IN="7d"

# --- SERVER ---
PORT=5000
NODE_ENV="development"

# --- FRONTEND ---
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
NEXT_PUBLIC_APP_NAME="AUTOVERSE"

# --- CORS ---
FRONTEND_URL="http://localhost:3000"
